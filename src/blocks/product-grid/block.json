{
    "apiVersion": 3,
    "name": "amazing-online-store/product-grid",
    "title": "AOS Product Grid",
    "category": "widgets",
    "icon": "grid-view",
    "description": "Grid moderno de productos WooCommerce.",
    "supports": {
        "html": false
    },
    "attributes": {
        "productsToShow": {
            "type": "number",
            "default": 4
        },
        "columns": {
            "type": "number",
            "default": 4
        },
        "animation": {
            "type": "string",
            "default": "fade-up"
        },
        "animationDuration": {
            "type": "number",
            "default": 800
        },
        "animationDelay": {
            "type": "number",
            "default": 0
        },
        "animationOffset": {
            "type": "number",
            "default": 80
        },
        "animationOnce": {
            "type": "boolean",
            "default": true
        },
        "titleFontSize": {
            "type": "number",
            "default": 18
        },
        "titleFontWeight": {
            "type": "string",
            "default": "600"
        },
        "titleTextColor": {
            "type": "string",
            "default": "#111111"
        },
        "cardPaddingVertical": {
            "type": "number",
            "default": 18
        },
        "cardPaddingHorizontal": {
            "type": "number",
            "default": 18
        },
        "gridGap": {
            "type": "number",
            "default": 24
        },
        "cardRadius": {
            "type": "number",
            "default": 18
        },
        "cardBackground": {
            "type": "string",
            "default": "#ffffff"
        },
        "cardBorderWidth": {
            "type": "number",
            "default": 0
        },
        "cardBorderColor": {
            "type": "string",
            "default": "#e5e7eb"
        },
        "cardShadow": {
            "type": "string",
            "default": "soft"
        },
        "buttonRadius": {
            "type": "number",
            "default": 12
        },
        "buttonPaddingY": {
            "type": "number",
            "default": 12
        },
        "buttonPaddingX": {
            "type": "number",
            "default": 22
        },
        "buttonBg": {
            "type": "string",
            "default": "#111111"
        },
        "buttonTextColor": {
            "type": "string",
            "default": "#ffffff"
        },
        "queryType": {
            "type": "string",
            "default": "recent"
        }
    },
    "editorScript": "file:./index.js",
    "style": "file:./style.css",
    "editorStyle": "file:./editor.css",
    "render": "file:./render.php"
}